generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Token {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String   @unique
  access_token  String?
  refresh_token String?
  scope         String?
  token_type    String?
  expiry_date   BigInt?
  
  // Relations
  actions       Action[]

  @@map("tokens")
}

model Action {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  message    String
  created_at DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  token      Token    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("actions")
}
